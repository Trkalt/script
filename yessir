    title.Parent = game.Players.LocalPlayer.PlayerGui.ScreenGui

    local subtitle = Instance.new("TextLabel")
    subtitle.Text = "made with ai"
    subtitle.Size = UDim2.new(0, 400, 0, 50)
    subtitle.Position = UDim2.new(0.5, -200, 0.5, 50)
