    -- Sensitivity Input Handling
    sensInputBox.FocusLost:Connect(function()
        local value = tonumber(sensInputBox.Text)
        if value and value >= SENSITIVITY_MIN and value <= SENSITIVITY_MAX then
            sensitivity = value
            sensLabel.Text = "Sensitivity: " .. sensitivity
            sensInputBox.Text = tostring(sensitivity)
        else
            sensInputBox.Text = tostring(sensitivity)
        end
    end)

    -- FOV Input Handling
    fovInputBox.FocusLost:Connect(function()
        local value = tonumber(fovInputBox.Text)
        if value and value >= 50 and value <= 300 then
            fovValue = value
            fovLabel.Text = "FOV: " .. fovValue .. " px"
            fovInputBox.Text = tostring(fovValue)
            circleFrame.Size = UDim2.new(0, fovValue * 2, 0, fovValue * 2)
            circleFrame.Position = UDim2.new(0.5, -fovValue, 0.5, -fovValue)
        else
            fovInputBox.Text = tostring(fovValue)
        end
    end)

    toggleBtn.MouseButton1Click:Connect(function()
        aimlockEnabled = not aimlockEnabled

        if aimlockEnabled then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            toggleBtn.Text = "AIMLOCK: ON"
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            toggleBtn.Text = "AIMLOCK: OFF"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            statusLabel.Text = "Status: Ready\nTarget: None\nWall Check: OK"
            distLabel.Text = "Distance: N/A"
            espLabel.Text = "ESP: Inactive"
        end
    end)

    RunService.RenderStepped:Connect(function()
        -- Update FOV Circle Position
        circleFrame.Position = UDim2.new(0.5, -fovValue, 0.5, -fovValue)

        if aimlockEnabled then
            local target, distance = detectTargets(fovValue)
            currentTarget = target
            
            local espTargets = updateESP()
            espLabel.Text = "ESP: " .. #espTargets .. " targets visible"

            if currentTarget then
                aimAtTarget(currentTarget)
                statusLabel.Text = "Status: Active\nTarget: " .. currentTarget.Name .. "\nWall Check: PASSED"
                distLabel.Text = "Distance: " .. math.floor(distance) .. " studs"
            else
                statusLabel.Text = "Status: Active\nTarget: Searching...\nWall Check: OK"
                distLabel.Text = "Distance: N/A"
            end
        end
    end)

    print("[AIMLOCK v3.0] Script fully loaded and ready!")
end

main()
