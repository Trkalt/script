    loadingGui.ResetOnSpawn = false
    loadingGui.Parent = PlayerGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bg.BorderSizePixel = 0
    bg.Parent = loadingGui

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 100)
    title.Position = UDim2.new(0, 0, 0.35, 0)
    title.BackgroundTransparency = 1
    title.Text = "AIMLOCK v3.0 - IMPROVED"
    title.TextColor3 = Color3.fromRGB(0, 255, 0)
    title.TextSize = 50
    title.Font = Enum.Font.GothamBold
    title.Parent = bg

    local barBg = Instance.new("Frame")
    barBg.Size = UDim2.new(0, 300, 0, 8)
    barBg.Position = UDim2.new(0.5, -150, 0.6, 0)
    barBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    barBg.BorderSizePixel = 0
    barBg.Parent = bg

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 0, 0, 8)
    bar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    bar.BorderSizePixel = 0
    bar.Parent = barBg

    local startTime = tick()
    while tick() - startTime < LOADING_TIME do
        local progress = (tick() - startTime) / LOADING_TIME
        bar.Size = UDim2.new(progress, 0, 0, 8)
        wait(0.01)
    end

    for i = 1, 20 do
        bg.BackgroundTransparency = i / 20
        title.TextTransparency = i / 20
        wait(0.025)
    end

    loadingGui:Destroy()
end

