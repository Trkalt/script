-- Section 6: Main GUI 
local mainGui = Instance.new("ScreenGui")
mainGui.Parent = Player:WaitForChild("PlayerGui") 

local toggleButton = Instance.new("TextButton", mainGui)

-- Button properties
toggleButton.Size = UDim2.new(0.1, 0, 0.05, 0)
toggleButton.Position = UDim2.new(0.9, 0, 0.9, 0)
toggleButton.Text = "AIMLOCK"

-- Section 7: Target Detection 
local function findTargets() 
    targets = {} 
    for _, player in pairs(game.Players:GetPlayers()) do 
        if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
            table.insert(targets, player) 
        end
    end
end

-- Section 8: Aimlock Logic 
local function aimlock() 
    if aimlockEnabled and #targets > 0 then 
        local target = targets[1]
        if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then 
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.HumanoidRootPart.Position) 
        end
    end
end

-- Section 9: Slider Functionality 
local slider = Instance.new("Slider", mainGui)
slider.Size = UDim2.new(0.5, 0, 0.1, 0)
slider.Position = UDim2.new(0.1, 0, 0.8, 0)

slider.Changed:Connect(function() 
    sensitivity = slider.Value 
end)

-- Section 10: Event Handlers 
toggleButton.MouseButton1Down:Connect(function() 
    aimlockEnabled = not aimlockEnabled 
    toggleButton.Text = aimlockEnabled and "AIMLOCK ON" or "AIMLOCK OFF" 
end)

-- Section 11: Main Execution 
RunService.RenderStepped:Connect(function() 
    safeCall(findTargets)
    safeCall(aimlock)
end) 
